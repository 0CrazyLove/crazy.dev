---
import "../styles/global.css";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Crazy - Backend Developer Portfolio"
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/crazy.dev/heart.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style>
			@import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap");
		</style>
	</head>
	<body class="min-h-screen overflow-x-hidden">
		<!-- Ambient Glow Orbs -->
		<div
			class="fixed rounded-full pointer-events-none blur-[140px] z-0 will-change-[transform,opacity] transform-3d w-[550px] h-[550px] bg-[#b8976a] opacity-[0.08] -top-[5%] -right-[8%] animate-orb-drift-1"
			aria-hidden="true"
		>
		</div>
		<div
			class="fixed rounded-full pointer-events-none blur-[140px] z-0 will-change-[transform,opacity] transform-3d w-[650px] h-[650px] bg-[#7a6f5a] opacity-[0.12] bottom-[10%] -left-[10%] animate-orb-drift-2"
			aria-hidden="true"
		>
		</div>
		<div
			class="fixed rounded-full pointer-events-none blur-[140px] z-0 will-change-[transform,opacity] transform-3d w-[450px] h-[450px] bg-[#c4a67a] opacity-[0.07] top-[50%] right-[5%] animate-orb-drift-3"
			aria-hidden="true"
		>
		</div>

		<div class="relative z-10">
			<slot />
		</div>
	</body>
</html>
